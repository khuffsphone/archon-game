{
  "name": "archon-game",
  "private": true,
  "version": "3.7.0",
  "description": "Archon — Strategy board game with 2D arena combat",
  "author": "Headless Studios",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "electron:dev": "npm run build && electron .",
    "electron:package": "npm run build && node package-electron.mjs",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^31.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.5"
  },
  "build": {
    "appId": "com.headlessstudios.archon",
    "productName": "Archon",
    "copyright": "Headless Studios 2026",
    "forceCodeSigning": false,
    "files": [
      "dist/**/*",
      "electron/main.cjs",
      "electron/icon.png"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable",
      "icon": "electron/icon.ico",
      "signtoolOptions": null
    },
    "portable": {
      "artifactName": "Archon-v3.7-portable.exe"
    }
  }
}
